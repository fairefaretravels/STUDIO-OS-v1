{
  "version": "1.0",
  "timezone": "EST",
  "blocks": [
    {
      "type": "music_block",
      "duration": 1500,
      "repeat": true,
      "insertCommercialEvery": 900,
      "playlist": [
        "switchlades-distant-lover",
        "switchlades-always-getting-high"
      ]
    },
    {
      "type": "show",
      "id": "slept-on",
      "duration": 1800
    },
    {
      "type": "track",
      "id": "stv-teaser",
      "label": "COMING UP ON STV",
      "duration": 30
    },
    {
      "type": "show",
      "id": "g4e-live",
      "duration": 3600
    },
    {
      "type": "track",
      "id": "griff-trailer",
      "label": "G4E FEATURE TRAILER",
      "duration": 180
    },
    {
      "type": "show",
      "id": "professor-griff",
      "duration": 964
    },
    {
      "type": "show",
      "id": "vibezz",
      "duration": 120
    }
  ]
}                        title: track
                    });

                    runtime += 180;
                    i++;

                    if (
                        block.insertCommercialEvery &&
                        runtime % block.insertCommercialEvery === 0
                    ) {
                        push({
                            id: "commercial",
                            type: "commercial",
                            duration: 30,
                            title: "Commercial Break"
                        });
                    }

                    if (!block.repeat && i >= block.playlist.length) break;
                }
            }

            // SHOW BLOCK
            else if (block.type === "show") {
                push({
                    id: block.id,
                    type: "show",
                    duration: block.duration,
                    title: block.id
                });
            }

            // TRACK BLOCK
            else if (block.type === "track") {
                push({
                    id: block.id,
                    type: "track",
                    duration: block.duration,
                    title: block.label || block.id
                });
            }
        }

        return queue;
    }

    // =========================
    // UI UPDATE
    // =========================
    function updateUI(item) {
        const title = item.title || item.id || "Commercial Break";
        const subtitle = item.type || "Live Programming";

        UI.npTitle()?.innerText = title;
        UI.npSub()?.innerText = subtitle;
        UI.ltHeadline()?.innerText = title;
        UI.ltSubheadline()?.innerText = subtitle;

        UI.tickerText()?.innerText =
            `STV LIVE • NOW PLAYING: ${title} • ${subtitle}`;

        const banner = UI.banner();
        if (banner) {
            banner.classList.remove("show");
            setTimeout(() => banner.classList.add("show"), 50);
            setTimeout(() => banner.classList.remove("show"), 5000);
        }

        const overlay = UI.commercialOverlay();
        if (overlay) {
            overlay.classList.toggle("show", item.type === "commercial");
        }
    }

    // =========================
    // LOAD MEDIA
    // =========================
    function load(item) {
        const player = UI.player();
        const frame = UI.frame();

        if (!player || !frame) {
            console.error("Missing player elements");
            return;
        }

        const src = item.url || item.src;

        updateUI(item);
        clearAdvance();

        if (!src) {
            console.error("Missing media src:", item);
            next();
            return;
        }

        // ---------- DRIVE ----------
        if (isDriveLink(src)) {

            player.pause();
            player.removeAttribute("src");
            player.style.display = "none";

            frame.style.display = "block";
            frame.src = toDrivePreview(src);

            scheduleAdvance(item.duration || 30);
            return;
        }

        // ---------- VIDEO ----------
        frame.style.display = "none";
        frame.src = "about:blank";

        player.style.display = "block";
        player.loop = !!item.loop;
        player.src = src;

        player.oncanplay = () => {
            player.play().catch(console.error);

            if (item.loop) {
                scheduleAdvance(item.duration || 30);
            }
        };

        player.onended = () => {
            if (!item.loop) next();
        };

        player.onerror = () => {
            console.error("Media failed:", item);
            next();
        };
    }

    // =========================
    // NEXT ITEM
    // =========================
    function next() {
        if (isTransitioning) return;
        if (!queue.length) return;

        isTransitioning = true;
        clearAdvance();

        const player = UI.player();
        if (player) player.style.opacity = 0.3;

        setTimeout(() => {
            index = (index + 1) % queue.length;
            load(queue[index]);

            if (player) player.style.opacity = 1;
            isTransitioning = false;
        }, 500);
    }

    // =========================
    // START ENGINE
    // =========================
    async function start(schedule) {

        const raw = schedule?.blocks
            ? schedule
            : (STUDIO?.generate ? await STUDIO.generate() : null);

        if (!raw) {
            console.error("No schedule provided");
            return;
        }

        queue = compileSchedule(raw);
        index = 0;

        if (!queue.length) {
            console.error("Compiled queue is empty");
            return;
        }

        load(queue[0]);
    }

    // =========================
    // PUBLIC API
    // =========================
    return {
        start
    };

})();
